{
	"port": 3000,
	"staticDir": "../frontend/public",
	"heartbeatInterval": 30,
	"modelList": ["gpt-4o", "gpt-4o-mini"],
	"streaming": {
		"enabled": true,
		"bufferWords": 0
	},
	"upstreams": [
		{
			"id": "local-main",
			"label": "Local (main model)",
			"url": "http://localhost:8080",
			"type": "llamacpp",
			"apiKey": null
		},
		{
			"id": "openai-subagent",
			"label": "OpenAI (subagent)",
			"url": "https://api.openai.com",
			"type": "openai",
			"apiKey": "$OPENAI_KEY",
			"modelList": ["gpt-4o", "gpt-4o-mini"]
		}
	]
}
